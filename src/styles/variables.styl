/* ===== 基础变量定义 ===== */
:root
  --radius-large: 1rem
  --content-delay: 150ms

/* ===== 主题相关变量 ===== */
/* 品牌定制：固定蓝色调，不随主题色相变化 */
:root
  /* 主品牌色 - 你的色板 */
  --brand-blue: #2E6CB8
  --brand-blue-deep: #2B5DAA
  --brand-blue-mid: #3C70AE
  --brand-blue-darker: #325E98
  --brand-blue-alt: #2B63AD
  --brand-blue-strong: #3467B6
  --brand-blue-light: #749DDB
  --brand-cream: #FBF9F1
  --brand-charcoal: #FBF9F1

  --primary: var(--brand-blue)
  --page-bg: var(--brand-cream)
  --card-bg: white
  --card-bg-transparent: unquote("rgb(255 255 255 / var(--card-transparent-opacity, 0.6))")

  --btn-content: var(--brand-blue)
  --btn-regular-bg: rgba(46, 108, 184, 0.10)
  --btn-regular-bg-hover: var(--brand-blue)
  --btn-regular-bg-active: var(--brand-blue-deep)

  --btn-plain-bg-hover: rgba(46, 108, 184, 0.08)
  --btn-plain-bg-active: rgba(46, 108, 184, 0.15)

  --btn-card-bg-hover: rgba(46, 108, 184, 0.06)
  --btn-card-bg-active: rgba(46, 108, 184, 0.12)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: var(--brand-charcoal)
  --title-active: var(--brand-blue)

  --line-divider: rgba(67, 76, 84, 0.10)
  --line-color: rgba(67, 76, 84, 0.15)
  --meta-divider: rgba(67, 76, 84, 0.20)
  --content-meta: rgba(67, 76, 84, 0.70)

  --inline-code-bg: rgba(46, 108, 184, 0.10)
  --inline-code-color: var(--brand-blue)
  --muted: rgba(46, 108, 184, 0.08)
  --selection-bg: rgba(46, 108, 184, 0.20)
  --codeblock-bg: #1A2742
  --codeblock-topbar-bg: #0F1A2E

  --license-block-bg: rgba(0, 0, 0, 0.03)

  --link-underline: rgba(46, 108, 184, 0.40)
  --link-hover: var(--brand-blue)
  --link-active: var(--brand-blue-deep)

  --float-panel-bg: white

  --scrollbar-bg-light: rgba(0, 0, 0, 0.4)
  --scrollbar-bg-hover-light: rgba(0, 0, 0, 0.5)
  --scrollbar-bg-active-light: rgba(0, 0, 0, 0.6)

  --scrollbar-bg-dark: rgba(255, 255, 255, 0.4)
  --scrollbar-bg-hover-dark: rgba(255, 255, 255, 0.5)
  --scrollbar-bg-active-dark: rgba(255, 255, 255, 0.6)

  --scrollbar-bg: var(--scrollbar-bg-light)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light)

  --display-light-icon: 1
  --display-dark-icon: 0

  --admonitions-color-tip: #749DDB
  --admonitions-color-note: #2E6CB8
  --admonitions-color-important: #3467B6
  --admonitions-color-warning: #DBA874
  --admonitions-color-caution: #DB7474

  /* TOC相关变量 - 蓝色调 */
  --toc-badge-bg: rgba(46, 108, 184, 0.12)
  --toc-btn-hover: rgba(46, 108, 184, 0.10)
  --toc-btn-active: rgba(46, 108, 184, 0.18)
  --toc-indicator-bg: rgba(46, 108, 184, 0.10)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: var(--brand-blue)

  /* Live2D 消息框变量 */
  --l2d-msg-bg: var(--brand-blue)

  /* 主题色选择条渐变 - 你的色板 */
  --color-selection-bar: linear-gradient(to right, #FBF9F1, #FBF9F1, #FBF9F1, #2E6CB8, #2B5DAA, #3C70AE, #325E98, #2B63AD, #749DDB, #3467B6, #434C54, #434C54)

/* 卡片风格跟随主题色相 */
:root:not(.dark) body.card-follow-theme-hue
  --card-bg: rgba(251, 249, 241, 0.6)

/* 暗色主题变量 - 全部蓝色调 */
:root.dark
  --primary: var(--brand-blue-light)
  --page-bg: #0F1A2E
  --card-bg: #1A2742
  --card-bg-transparent: unquote("rgb(26 39 66 / var(--card-transparent-opacity, 0.6))")

  --btn-content: var(--brand-cream)
  --btn-regular-bg: rgba(116, 157, 219, 0.15)
  --btn-regular-bg-hover: var(--brand-blue-light)
  --btn-regular-bg-active: var(--brand-blue)

  --btn-plain-bg-hover: rgba(116, 157, 219, 0.10)
  --btn-plain-bg-active: rgba(116, 157, 219, 0.18)

  --btn-card-bg-hover: rgba(116, 157, 219, 0.08)
  --btn-card-bg-active: rgba(116, 157, 219, 0.15)

  --line-divider: rgba(116, 157, 219, 0.12)
  --line-color: rgba(116, 157, 219, 0.15)
  --meta-divider: rgba(251, 249, 241, 0.20)
  --content-meta: rgba(251, 249, 241, 0.70)

  --muted: rgba(116, 157, 219, 0.10)
  --selection-bg: rgba(116, 157, 219, 0.25)
  --codeblock-bg: #0F1A2E
  --codeblock-topbar-bg: #0A1426

  --license-block-bg: var(--codeblock-bg)

  --link-underline: rgba(116, 157, 219, 0.40)
  --link-hover: var(--brand-blue-light)
  --link-active: var(--brand-blue)

  --float-panel-bg: #1A2742

  --scrollbar-bg: var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-dark)

  --display-light-icon: 0
  --display-dark-icon: 1

  --admonitions-color-tip: #749DDB
  --admonitions-color-note: #749DDB
  --admonitions-color-important: #B49DDB
  --admonitions-color-warning: #DBB074
  --admonitions-color-caution: #DB9090

  /* TOC相关变量 - 暗色主题 */
  --toc-badge-bg: rgba(116, 157, 219, 0.18)
  --toc-btn-hover: rgba(116, 157, 219, 0.12)
  --toc-btn-active: rgba(116, 157, 219, 0.20)
  --toc-indicator-bg: rgba(116, 157, 219, 0.12)
  --toc-item-active: var(--brand-blue-light)

  /* Live2D 消息框变量 - 暗色主题 */
  --l2d-msg-bg: var(--brand-blue-light)

  /* 主题色选择条渐变 - 暗色主题 */
  --color-selection-bar: linear-gradient(to right, #749DDB, #3467B6, #2E6CB8, #2B5DAA, #3C70AE, #325E98, #2B63AD, #749DDB, #3467B6, #434C54, #1A2742, #1A2742)

/* ===== 响应式断点变量 ===== */
:root
  /* 断点定义 */
  --breakpoint-xs: 320px
  --breakpoint-sm: 480px
  --breakpoint-md: 768px
  --breakpoint-lg: 1024px
  --breakpoint-xl: 1280px
  --breakpoint-2xl: 1536px
  
  /* 容器宽度 */
  --container-xs: 100%
  --container-sm: 100%
  --container-md: 100%
  --container-lg: 1024px
  --container-xl: 1280px
  --container-2xl: 1536px

/* ===== 动画变量 ===== */
:root
  /* 缓动函数 */
  --ease-standard: cubic-bezier(0.4, 0, 0.2, 1)
  --ease-decelerate: cubic-bezier(0.25, 0.46, 0.45, 0.94)
  --ease-accelerate: cubic-bezier(0.55, 0.055, 0.675, 0.19)
  --ease-sharp: cubic-bezier(0.4, 0, 0.6, 1)
  
  /* 动画时长 */
  --duration-fast: 100ms
  --duration-normal: 150ms
  --duration-medium: 200ms
  --duration-slow: 250ms
  --duration-slower: 300ms
  
  /* 动画延迟 */
  --delay-none: 0ms
  --delay-short: 30ms
  --delay-medium: 60ms
  --delay-long: 90ms
  --delay-longer: 120ms

/* ===== 间距变量 ===== */
:root
  /* 基础间距 */
  --spacing-xs: 0.25rem    /* 4px */
  --spacing-sm: 0.5rem     /* 8px */
  --spacing-md: 0.75rem    /* 12px */
  --spacing-lg: 1rem       /* 16px */
  --spacing-xl: 1.25rem    /* 20px */
  --spacing-2xl: 1.5rem    /* 24px */
  --spacing-3xl: 2rem      /* 32px */
  --spacing-4xl: 2.5rem    /* 40px */
  --spacing-5xl: 3rem      /* 48px */
  
  /* 组件间距 */
  --widget-gap-mobile: var(--spacing-md)
  --widget-gap-tablet: var(--spacing-lg)
  --widget-gap-desktop: var(--spacing-xl)
  
  /* 侧边栏宽度 */
  --sidebar-width-mobile: 100%
  --sidebar-width-tablet: 280px
  --sidebar-width-desktop: 320px

/* ===== 阴影变量 ===== */
:root
  /* 基础阴影 */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05)
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.1)
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.1)
  --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.1)
  --shadow-2xl: 0 25px 50px rgba(0, 0, 0, 0.25)
  
  /* 特殊阴影 */
  --shadow-navbar: 0 4px 16px rgba(0, 0, 0, 0.1)
  --shadow-navbar-dark: 0 4px 16px rgba(0, 0, 0, 0.2)
  --shadow-button: 0 4px 12px rgba(0, 0, 0, 0.15)
  --shadow-button-dark: 0 4px 12px rgba(255, 255, 255, 0.1)

/* ===== 边框半径变量 ===== */
:root
  --radius-sm: 0.25rem     /* 4px */
  --radius-md: 0.375rem    /* 6px */
  --radius-lg: 0.5rem      /* 8px */
  --radius-xl: 0.75rem     /* 12px */
  --radius-2xl: 1rem       /* 16px */
  --radius-3xl: 1.5rem     /* 24px */
  --radius-full: 9999px

/* ===== 透明度变量 ===== */
:root
  --opacity-0: 0
  --opacity-5: 0.05
  --opacity-10: 0.1
  --opacity-20: 0.2
  --opacity-25: 0.25
  --opacity-30: 0.3
  --opacity-40: 0.4
  --opacity-50: 0.5
  --opacity-55: 0.55
  --opacity-60: 0.6
  --opacity-70: 0.7
  --opacity-75: 0.75
  --opacity-80: 0.8
  --opacity-85: 0.85
  --opacity-90: 0.9
  --opacity-95: 0.95
  --opacity-100: 1

/* ===== 模糊效果变量 ===== */
:root
  --blur-sm: 4px
  --blur-md: 8px
  --blur-lg: 12px
  --blur-xl: 16px
  --blur-2xl: 20px
  --blur-3xl: 24px

/* ===== 变换变量 ===== */
:root
  /* 平移 */
  --translate-xs: 0.125rem   /* 2px */
  --translate-sm: 0.25rem     /* 4px */
  --translate-md: 0.5rem      /* 8px */
  --translate-lg: 0.75rem     /* 12px */
  --translate-xl: 1rem        /* 16px */
  --translate-2xl: 1.5rem      /* 24px */
  --translate-3xl: 2rem       /* 32px */
  
  /* 缩放 */
  --scale-95: 0.95
  --scale-98: 0.98
  --scale-100: 1
  --scale-105: 1.05
  --scale-110: 1.1

/* ===== 层级变量 ===== */
:root
  --z-dropdown: 1000
  --z-sticky: 1020
  --z-fixed: 1030
  --z-modal-backdrop: 1040
  --z-modal: 1050
  --z-popover: 1060
  --z-tooltip: 1070
  --z-toast: 1080
  --z-navbar: 20
  --z-banner: 10
  --z-content: 30

/* ===== 性能优化变量 ===== */
:root
  /* GPU加速 */
  --gpu-transform: translateZ(0)
  --gpu-backface: hidden
  
  /* 动画性能 */
  --animation-fill-mode: both
  --animation-timing: var(--ease-standard)
  --animation-duration: var(--duration-medium)

/* ===== 响应式工具类 ===== */
@media (max-width: 767px)
  :root
    --container-width: var(--container-sm)
    --widget-gap: var(--widget-gap-mobile)
    --sidebar-width: var(--sidebar-width-mobile)

@media (min-width: 768px) and (max-width: 1279px)
  :root
    --container-width: var(--container-md)
    --widget-gap: var(--widget-gap-tablet)
    --sidebar-width: var(--sidebar-width-tablet)

@media (min-width: 1280px)
  :root
    --container-width: var(--container-lg)
    --widget-gap: var(--widget-gap-desktop)
    --sidebar-width: var(--sidebar-width-desktop)
