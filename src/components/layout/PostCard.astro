---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getCategoryUrl, getTagUrl } from "@/utils/url-utils";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";

interface Props {
	class?: string;
	entry: CollectionEntry<"posts">;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string | null;
	description: string;
	draft: boolean;
	pinned?: boolean;
	password?: boolean;
	style: string;
}
const {
	entry,
	title,
	url,
	published,
	tags,
	category,
	description,
	pinned,
	password,
	style,
} = Astro.props;
const className = Astro.props.class;

const showTags = siteConfig.postListLayout.showTags;
const descriptionLines = Math.max(
	0,
	Math.trunc(siteConfig.postListLayout.descriptionLines ?? 2),
);
const descriptionClampLines = String(descriptionLines);
const shouldClampDescription = descriptionLines > 0;

const { remarkPluginFrontmatter } = await render(entry);
const descriptionText = description || remarkPluginFrontmatter.excerpt || "";
---

<div
  class:list={[
    "post-card-wrapper",
    pinned ? "pinned" : "",
    "card-base flex flex-col-reverse w-full rounded-(--radius-large) overflow-hidden relative",
    className,
  ]}
  style={style}
>
  <div
    class:list={[
      "post-card-content",
      "pl-4 md:pl-9 pr-4 md:pr-6 pt-4 md:pt-7 pb-4 md:pb-7 relative flex flex-col h-full",
      "w-full",
    ]}
  >
    <div class="flex items-start gap-3">
      <a
        href={url}
        class="post-card-title transition group flex-1 font-bold text-3xl text-90
          hover:text-(--primary) dark:hover:text-(--primary)
          active:text-(--title-active) dark:active:text-(--title-active)
          before:w-1 before:h-5 before:rounded-md before:bg-(--primary)
          before:absolute before:top-[35px] before:left-[18px] before:hidden md:before:block"
      >
        {title}

        {
          password && (
            <Icon
              is:inline
              name="material-symbols:lock-outline"
              class="inline text-2xl align-middle -translate-y-px"
            />
          )
        }
      </a>

      {pinned && (
        <Icon
          is:inline
          name="material-symbols:push-pin-outline"
          class="text-xl text-gray-400 dark:text-gray-500 shrink-0"
        />
      )}
    </div>

    <div
      class:list={[
        "transition text-75 md:pr-4 description grow",
        { "description-clamped": shouldClampDescription },
      ]}
      title={descriptionText}
    >
      {descriptionText}
    </div>

    <!-- category + tags + date -->
    {
      showTags && (
        <div class="flex flex-wrap items-center justify-between gap-2 transition stats pt-3">
          <div class="flex flex-wrap items-center gap-2">
            <!-- category -->
            {category && (
              <>
                <a
                  href={getCategoryUrl(category)}
                  aria-label={`View all posts in the ${category} category`}
                  class="text-xs text-gray-400 dark:text-gray-500 transition-colors duration-200 hover:text-blue-500"
                >
                  {category}
                </a>
                <span class="text-gray-300 dark:text-gray-600 select-none">|</span>
              </>
            )}
            {!(tags && tags.length > 0) && !category && (
              <span class="text-(--content-meta) text-xs">
                #{i18n(I18nKey.noTags)}
              </span>
            )}
            <!-- tags -->
            {tags && tags.length > 0 && (
              <div class="flex flex-wrap items-center gap-1">
                {tags.map((tag) => (
                  <a
                    href={getTagUrl(tag)}
                    aria-label={`View all posts with the ${tag.trim()} tag`}
                    class="text-xs text-gray-400 dark:text-gray-500 transition-colors duration-200 hover:text-blue-500 ml-2 first:ml-0"
                  >
                    #{tag.trim()}
                  </a>
                ))}
              </div>
            )}
          </div>
          <!-- date on the right -->
          <span class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap shrink-0">
            {formatDateToYYYYMMDD(published)}
          </span>
        </div>
      )
    }
  </div>
</div>

<style define:vars={{ descriptionClampLines }}>
  .description-clamped {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    -webkit-line-clamp: var(--descriptionClampLines);
    line-clamp: var(--descriptionClampLines);
  }

  :global(.post-card-title) {
    margin-bottom: 0 !important;
  }

  /* 默认（无 layout class 时的刷新状态） */
  .stats {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 0.5rem !important;
  }

  .stats a {
    color: #9ca3af !important;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .stats a:hover {
    color: #325E98 !important;
  }

  /* === List Mode Mobile Styles === */
  :global(.list-mode) .post-card-wrapper {
    flex-direction: row !important;
  }

  :global(.list-mode) .post-card-title {
    font-size: 1.125rem !important;
    line-height: 1.75rem !important;
    margin-bottom: 0 !important;
  }

  :global(.list-mode) .post-card-title::before {
    display: none !important;
  }

  /* 移动端列表模式 - 隐藏tags，只在有空间时显示 */
  :global(.list-mode) .stats {
    gap: 0.25rem !important;
    font-size: 0.65rem !important;
  }

  /* === Desktop List Mode overrides === */
  @media (min-width: 768px) {
    :global(.list-mode) .post-card-wrapper {
      flex-direction: row !important;
    }

    :global(.list-mode) .post-card-title {
      font-size: 1.5rem !important;
      line-height: 2rem !important;
      margin-bottom: 0.75rem !important;
    }

    :global(.list-mode) .post-card-title::before {
      display: block !important;
      top: 2.25rem !important;
      height: 1rem !important;
    }

    :global(.list-mode) .description {
      font-size: inherit !important;
    }

    :global(.list-mode) .stats {
      font-size: 0.75rem !important;
    }
  }

  /* === Grid Mode Styles === */
  :global(.grid-mode) .post-card-wrapper {
    flex-direction: column-reverse !important;
    height: 100% !important;
    justify-content: flex-end !important;
  }

  :global(.grid-mode) .post-card-content {
    width: 100% !important;
    height: auto !important;
    flex-grow: 1 !important;
  }

  :global(.grid-mode) .description {
    flex-grow: 0 !important;
  }

  :global(.grid-mode) .stats {
    margin-top: auto !important;
  }
</style>
